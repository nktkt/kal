# 比較・等価・剰余・論理・単項演算子

10 % 3;               # => 1   (剰余)
3 == 3;               # => 1   (== は数値・bool に使える)
(2 < 3) == (4 > 1);   # => 1   (bool 同士の ==)
-5 + 8;               # => 3   (単項マイナス)
!(3 == 4);            # => 1   (論理否定)

# 短絡 && / ||
fn even(n: i64) -> bool = n % 2 == 0;

even(10) && even(4);  # => 1
even(3) || even(8);   # => 1
