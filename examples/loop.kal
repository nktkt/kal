# for ループと組み込み出力 (戻り値型を省略すると unit)

fn printstars(n: i32) =
  for i = 1, i < n, 1 in
    putchard(42);          # 42 = '*'

printstars(11);            # => '*' を 10 個
putchard(10);              # 改行 (10 = '\n')

# 1〜5 の 2 乗を表示 (i32 を i64 にキャストして printi へ)
fn square(x: i32) -> i32 = x * x;

for i = 1, i < 6, 1 in
  printi(square(i) as i64);
