# for ループと組み込み関数

# putchard は文字コードを 1 文字出力する (65 = 'A')
# for i = 開始, 継続条件, ステップ in 本体
def printstars(n)
  for i = 1, i < n, 1 in
    putchard(42);   # 42 = '*'

# '*' を 10 個並べて改行 (10 = '\n')
printstars(11);
putchard(10);

# 1 から 5 までの 2 乗を表示
def square(x) x * x;
for i = 1, i < 6, 1 in printd(square(i));
