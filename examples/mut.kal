# ブロック { ... }・let mut・代入・&mut 経由の変更

# 可変アキュムレータでループ (ブロック本体の関数)
fn triangle(n: i32) -> i32 = {
  let mut s = 0;
  for i = 1, i < n, 1 in {
    s = s + i;
  };
  s            # ブロック末尾の式がブロックの値
};

triangle(6);          # => 15  (1+2+3+4+5)

# &mut 参照で呼び出し側の変数を変更する
fn incr(p: &mut i64) = {
  *p = *p + 1;
};

{
  let mut x: i64 = 41;
  incr(&mut x);
  x
};                    # => 42
